# Master oriz hub — env contract for the family
#
# This file is checked into git as a TEMPLATE. The actual values live at
# C:/D/oriz/.env (gitignored) and are populated by reading from the envpact
# vault at chirag127/envpact-secrets.
#
# Every sub-site has its own .env.example documenting the same shared keys
# plus any site-specific extras. Run `npx envpact-cli@0.2.0` from a sub-site
# directory to generate that site's .env.

# ---- Firebase (shared via envpact 'shared' block) ----
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=auth.oriz.in
PUBLIC_FIREBASE_PROJECT_ID=oriz-app
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# ---- Cloudflare ----
PUBLIC_CF_BEACON_TOKEN=
PUBLIC_CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ---- Forms / newsletter / comments ----
PUBLIC_WEB3FORMS_KEY=
PUBLIC_BUTTONDOWN_USERNAME=chirag127
PUBLIC_GISCUS_REPO=chirag127/oriz
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=

# ---- Error tracking ----
PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---- Analytics ----
PUBLIC_GA4_ID=

# ---- AdSense (uncomment ONLY after publisher approval) ----
# PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_FUNDING_CHOICES_ID=

# ---- npm publish (added 2026-06-20) ----
# https://www.npmjs.com/settings/chirag127/tokens — Granular Access Token
# Scopes: @chirag127/* → Read+Write — 90-day TTL
NPM_TOKEN=

# ---- Monetization (every site except chirag127/me, added 2026-06-20) ----
# https://buymeacoffee.com/dashboard/account-settings → username
PUBLIC_BMAC_USERNAME=chirag127

# ---- Analytics extras (added 2026-06-20) ----
# https://posthog.com → project → API keys → Project API Key
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# https://clarity.microsoft.com → project → setup → ID
PUBLIC_CLARITY_PROJECT_ID=

# ---- Search (added 2026-06-20) ----
# https://www.algolia.com → application → API keys → Search-Only API Key
PUBLIC_ALGOLIA_APP_ID=
PUBLIC_ALGOLIA_SEARCH_KEY=

# ---- AI gating (added 2026-06-20) ----
# Set false to disable Puter.js AI features per-site
PUBLIC_PUTER_ENABLED=true

# ---- envpact (used by the action in CI) ----
ENVPACT_VAULT_TOKEN=

# ---- Build perf (Windows EMFILE workaround) ----
UV_THREADPOOL_SIZE=64
