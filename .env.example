# oriz family — master .env.example
# ============================================
# This file is the SINGLE source of truth for every environment variable
# the chirag127/oriz family uses. Copy to .env (gitignored) and populate.
#
# Per knowledge/decisions/security/env-and-secrets-single-source.md:
#   Track A — this file (.env.example, key names only, PUBLIC)
#   Track B — real secrets at GitHub org-level via:
#       gh secret set <KEY> --org chirag127 --visibility all
#   Doppler stays upstream source of truth.
#
# Per knowledge/decisions/security/secrets-management-doppler.md:
#   Doppler is the master. GitHub Secrets / Cloudflare / Firebase config
#   are runtime mirrors of Doppler. Pull with `doppler secrets download`.
#
# Conventions:
#   PUBLIC_*  = safe to ship to browser via import.meta.env
#   (no prefix) = server-only, never ship to browser
#
# Add a new key here FIRST, then add to Doppler, then `gh secret set`.
# CI fails if .env.example drifts across repos
# (templates/.env.example is canonical).

# ============================================
#  CLOUDFLARE
# ============================================
# Dashboard: https://dash.cloudflare.com/profile/api-tokens
# Permissions to grant on the API token:
#   - Account.Cloudflare Pages:Edit
#   - Account.Workers Scripts:Edit
#   - Zone.DNS:Edit
#   - Zone.Cache Purge:Purge
#   - Zone.Page Rules:Edit
#   - Zone.Workers Routes:Edit
# Account/Zone resources: account = yours, zone = oriz.in
# TTL: 1 year max
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL=
CLOUDFLARE_ZONE_ID=

# Cloudflare Web Analytics (cookieless, GDPR-safe)
# https://one.dash.cloudflare.com/?to=/:account/web-analytics
PUBLIC_CF_BEACON_TOKEN=

# Cloudflare Turnstile (CAPTCHA — primary)
# https://dash.cloudflare.com/?to=/:account/turnstile
PUBLIC_CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET=

# Cloudflare R2 (paid object storage — DO NOT USE per no-card rule)
# Listed for completeness. Use Backblaze B2 instead.
# CLOUDFLARE_R2_ACCESS_KEY=
# CLOUDFLARE_R2_SECRET_KEY=

# ============================================
#  FIREBASE (shared across every site)
# ============================================
# Console: https://console.firebase.google.com/project/oriz-app
# Per family-stack-lock: single Firebase project for the whole family.
# auth.oriz.in is a custom auth domain.
# Spark plan only — never enable Blaze (per rules/no-card-on-file).
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=auth.oriz.in
PUBLIC_FIREBASE_PROJECT_ID=oriz-app
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_TOKEN=
FIREBASE_SERVICE_ACCOUNT_KEY=

# ============================================
#  REGISTRAR (Spaceship)
# ============================================
# https://www.spaceship.com/application/api-key-manager/
# Used by CI to sync DNS to Cloudflare and check renewals.
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=
SPACESHIP_API_URL=https://spaceship.dev/api/v1

# ============================================
#  NPM
# ============================================
# https://www.npmjs.com/settings/chirag127/tokens
# Granular Access Token, scope @chirag127/*, Read+Write, 90-day TTL
NPM_TOKEN=

# ============================================
#  GITHUB
# ============================================
# https://github.com/settings/personal-access-tokens
# Fine-grained token: chirag127 org, all repos, scopes: contents:write,
# issues:write, pull_requests:write, workflows:write, packages:write.
GH_PAT=
GITHUB_TOKEN=
GH_USERNAME=chirag127

# ============================================
#  ANALYTICS (5-tier stack per decisions/architecture/analytics-five-tier-stack.md)
# ============================================
# 1. Cloudflare Web Analytics — token above (CF_BEACON_TOKEN)
# 2. Sentry (errors)
# https://sentry.io/settings/account/api/auth-tokens/
PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# 3. PostHog (product analytics + flags + replay primary)
# https://app.posthog.com/project/settings
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# 4. Microsoft Clarity (heatmap + replay redundant)
# https://clarity.microsoft.com/
PUBLIC_CLARITY_PROJECT_ID=

# 5. GA4 (marketing funnel)
# https://analytics.google.com
PUBLIC_GA4_MEASUREMENT_ID=

# Feature flags for each analytics tool (per Sentry pattern)
ENABLE_GA4=true
ENABLE_CLARITY=true
ENABLE_POSTHOG=true
ENABLE_SPEED_INSIGHTS=true
ENABLE_BETTER_STACK_LOGS=true

# Vercel Speed Insights (works on CF Pages — no Vercel hosting needed)
PUBLIC_SPEED_INSIGHTS_ID=

# ============================================
#  MONETIZATION (every site EXCEPT me-site)
# ============================================
# AdSense apex application — one app for oriz.in covers all subdomains
# https://www.google.com/adsense
PUBLIC_ADSENSE_CLIENT=
PUBLIC_FUNDING_CHOICES_ID=

# Razorpay (India primary billing)
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Lemon Squeezy (international fallback)
# https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Polar.sh (OSS-friendly MoR checkout)
# https://polar.sh/dashboard/settings
POLAR_ACCESS_TOKEN=

# keygen.sh (license-key fallback)
# https://app.keygen.sh
KEYGEN_ACCOUNT_ID=
KEYGEN_TOKEN=

# Donation rails
PUBLIC_BMAC_USERNAME=chirag127            # buymeacoffee.com/<user>
LIBERAPAY_USERNAME=                       # liberapay.com/<user>
OPEN_COLLECTIVE_SLUG=
GITHUB_SPONSORS_LOGIN=chirag127

# ============================================
#  AI (per ai-puter-plus-cf-workers-ai.md)
# ============================================
# Puter.js — user pays for AI on their own account (browser-side)
PUBLIC_PUTER_ENABLED=true

# Cloudflare Workers AI — server-side bindings, no key needed
# Bind in wrangler.toml: [ai] binding = "AI"

# ============================================
#  FORMS (per forms-trio.md)
# ============================================
# Web3Forms (primary)
# https://web3forms.com/dashboard
PUBLIC_WEB3FORMS_KEY=

# Static Forms (fallback)
# https://www.staticforms.xyz/dashboard
PUBLIC_STATIC_FORMS_KEY=

# Tally (rich / multi-step)
# https://tally.so/settings
PUBLIC_TALLY_FORM_ID=

# ============================================
#  COMMENTS — Giscus (per services/comments/giscus.md)
# ============================================
# https://giscus.app
PUBLIC_GISCUS_REPO=chirag127/oriz
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=

# ============================================
#  SEARCH
# ============================================
# Algolia (full-text search across sites)
# https://www.algolia.com/account/api-keys
PUBLIC_ALGOLIA_APP_ID=
PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=

# ============================================
#  NEWSLETTER (split per newsletter-split-buttondown-emailoctopus.md)
# ============================================
# Buttondown (technical / dev audience)
# https://buttondown.email/settings/programming
PUBLIC_BUTTONDOWN_USERNAME=chirag127
BUTTONDOWN_API_KEY=

# EmailOctopus (general marketing)
# https://emailoctopus.com/account/api-keys
EMAILOCTOPUS_API_KEY=

# Resend (transactional email only)
# https://resend.com/api-keys
RESEND_API_KEY=

# ============================================
#  PUSH NOTIFICATIONS (per notifications-fcm-plus-knock.md)
# ============================================
# Knock orchestrates; FCM is transport (covered by FIREBASE_VAPID_KEY above)
# https://dashboard.knock.app
KNOCK_API_KEY=
KNOCK_SIGNING_KEY=
PUBLIC_KNOCK_PUBLIC_API_KEY=

# ============================================
#  CROSS-POSTING (chirag127/echo-site)
# ============================================
DEVTO_API_KEY=                    # https://dev.to/settings/extensions
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=             # bsky.app → Settings → App passwords
HASHNODE_API_KEY=                 # https://hashnode.com/settings/developer
TELEGRAPH_ACCESS_TOKEN=
MASTODON_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
WORDPRESS_APP_PASSWORD=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=

# ============================================
#  MEDIA / ENTERTAINMENT APIS (chirag127/me-site lifestream)
# ============================================
# TMDB (Primary movie/TV layer)
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=

# Trakt (watched-history sync)
# https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=

# Fanart.tv / TVDB / TVMaze / Watchmode / OMDb (resilience layers)
FANART_API_KEY=
TVDB_API_KEY=
TVMAZE_API_KEY=
WATCHMODE_API_KEY=
OMDB_API_KEY=

# Last.fm (scrobble history)
# https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=
LASTFM_USERNAME=

# Spotify (now-playing)
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Steam (game library)
# https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
STEAM_USER_ID=

# YouTube (channel data)
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ============================================
#  DATA APIS (per data-apis-open-meteo-alpha-vantage.md)
# ============================================
# Open-Meteo (weather, no auth, unlimited free) — no key needed
# Alpha Vantage (finance, 25 req/day free)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ============================================
#  STORAGE (per object-storage-split.md)
# ============================================
# Backblaze B2 (unversioned blobs)
# https://secure.backblaze.com/app_keys.htm
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=oriz-blobs

# ============================================
#  IMAGE HOSTING (per image-host-four-tier.md)
# ============================================
# ImgBB (Tier 2)
# https://api.imgbb.com
IMGBB_KEY=

# Imgur (Tier 3)
# https://api.imgur.com/oauth2/addclient
IMGUR_CLIENT_ID=

# ============================================
#  WEBHOOK RELIABILITY (per hookdeck-for-webhook-reliability.md)
# ============================================
# Hookdeck (ingress queue)
# https://dashboard.hookdeck.com
HOOKDECK_SIGNING_SECRET=
HOOKDECK_SOURCE_TOKEN=

# ============================================
#  DATABASE (per db-add-neon-postgres.md)
# ============================================
# Neon Postgres (scale-to-zero)
# https://console.neon.tech
DATABASE_URL=

# Turso libSQL (warm cache)
# https://app.turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ============================================
#  MONITORING (per logs-better-stack-plus-cf-tail.md)
# ============================================
# Better Stack (status page + logs + uptime — same account, 3 products)
# https://logs.betterstack.com
BETTER_STACK_TOKEN=
BETTER_STACK_INGESTING_HOST=
BETTER_STACK_UPTIME_HEARTBEAT_URL=

# Axiom (metrics + tracing)
# https://app.axiom.co
AXIOM_TOKEN=
AXIOM_DATASET=

# Healthchecks.io (cron monitoring)
# https://healthchecks.io/projects/
HEALTHCHECKS_PING_URL=

# ============================================
#  SECURITY / AUTH
# ============================================
# Microsoft (Firebase Auth Microsoft provider)
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# hCaptcha (Turnstile fallback)
# https://dashboard.hcaptcha.com
PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# Google reCAPTCHA Enterprise (final fallback only)
RECAPTCHA_ENTERPRISE_KEY=

# ============================================
#  PRODUCTIVITY / TIME TRACKING
# ============================================
# Wakatime (auto coding time)
# https://wakatime.com/api-key
WAKATIME_API_KEY=

# ============================================
#  LIFESTREAM (oriz-me-site canonical store)
# ============================================
# Webhook secret for the JSONL ingester
# https://github.com/chirag127/oriz-me-data webhook secret
LIFESTREAM_INGEST_SECRET=

# Raindrop.io (linkroll source)
# https://app.raindrop.io/settings/integrations
RAINDROP_TOKEN=

# ============================================
#  DEV TOOLS
# ============================================
# Doppler (secrets master)
# https://dashboard.doppler.com
DOPPLER_SERVICE_TOKEN=
DOPPLER_PROJECT=oriz
DOPPLER_CONFIG=prd

# Envpact (vault sync)
ENVPACT_VAULT_TOKEN=

# ============================================
#  BUILD PERF
# ============================================
UV_THREADPOOL_SIZE=64
NODE_OPTIONS=--max-old-space-size=4096

# ============================================
#  DEPRECATED — DO NOT USE
# ============================================
# Listed so CI can grep these from any new code and fail.
# Spark/free-tier-friendly alternative is documented next to each.
#
# SURGE_TOKEN          — replaced by Cloudflare Pages
# NEOCITIES_API_KEY    — replaced by GitHub Pages mirror
# NEKOWEB_API_KEY      — replaced by GitHub Pages mirror
# APPWRITE_API_KEY     — replaced by Firebase Spark
# BING_SEARCH_API_KEY  — replaced by Brave Search via toolbox MCP
