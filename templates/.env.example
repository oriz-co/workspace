# oriz master .env.example
# Single source of truth. Gitignored locally; encrypted to .env.enc for sync.
# Runbook: knowledge/runbooks/env-management.md
# Last verified: 2026-06-22

# ==============================================================
# SECTION 1: TELEGRAM (notifications + drafts queue)
# ==============================================================
# Unified bot token from @BotFather; 4 chat IDs route by purpose
TELEGRAM_ANNOUNCE_CHAT_ID=     # public @oriz_announcements channel id
TELEGRAM_BOT_TOKEN=             # @BotFather → /newbot
TELEGRAM_DRAFTS_CHAT_ID=        # private @oriz_drafts (manual-platform queue)
TELEGRAM_OPS_CHAT_ID=           # private @oriz_ops (CI / mirror / health)
TELEGRAM_PAISA_CHAT_ID=         # public @oriz_paisa (finance content, opt-in)

# ==============================================================
# SECTION 2: FIREBASE (auth + Firestore — shared across all apps)
# ==============================================================
# Console: https://console.firebase.google.com/project/oriz-app (Spark plan only)
FIREBASE_SERVICE_ACCOUNT_JSON=  # console → Project Settings → Service accounts (JSON, single-line)
FIREBASE_TOKEN=                 # `firebase login:ci` output (CLI deploys)
PUBLIC_FIREBASE_API_KEY=        # console → Project Settings → General → Web app
PUBLIC_FIREBASE_APP_ID=         # console → Project Settings → General → Web app
PUBLIC_FIREBASE_AUTH_DOMAIN=auth.oriz.in
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=  # console → Project Settings → Cloud Messaging
PUBLIC_FIREBASE_PROJECT_ID=oriz-app
PUBLIC_FIREBASE_STORAGE_BUCKET=  # console → Storage (format: <id>.firebasestorage.app)

# ==============================================================
# SECTION 3: CLOUDFLARE (DNS + Pages + Workers; account-wide)
# ==============================================================
# Get token at https://dash.cloudflare.com/profile/api-tokens
# Required perms: Zone DNS+Cache+Rules+Settings+SSL Edit, Account Pages+Workers+Analytics
CLOUDFLARE_ACCOUNT_ID=          # zone overview → right sidebar
CLOUDFLARE_API_TOKEN=           # dash.cloudflare.com/profile/api-tokens (cfut_*)
CLOUDFLARE_EMAIL=               # account login email (for legacy Global API auth)

# ==============================================================
# SECTION 4: GITHUB (PAT + service tokens for sync)
# ==============================================================
# Required scope: repo (full); 1-year TTL
GH_ADMIN_PAT=                   # github.com/settings/tokens — admin repo ops
GH_PAT=                         # github.com/settings/tokens — read/write repos
GH_USERNAME=chirag127
GITHUB_TOKEN=                   # github.com/settings/tokens — default CI token

# ==============================================================
# SECTION 5: NPM (publish + Renovate)
# ==============================================================
NPM_TOKEN=                      # npmjs.com/settings/<user>/tokens (Granular, R+W, 90d)

# ==============================================================
# SECTION 6: SOPS / AGE (env encryption bootstrap)
# ==============================================================
# Bootstrap secret; pushed to GH workspace repo as SOPS_AGE_KEY
SOPS_AGE_KEY=                   # `age-keygen` → AGE-SECRET-KEY-1... (paired with .sops.yaml recipient)

# ==============================================================
# SECTION 7: SPACESHIP (oriz.in domain registrar)
# ==============================================================
SPACESHIP_API_KEY=              # spaceship.com/application/api-key-manager
SPACESHIP_API_SECRET=           # same dashboard, generated alongside key
SPACESHIP_API_URL=https://spaceship.dev/api/v1

# ==============================================================
# SECTION 8: RAZORPAY (subscriptions — INR rail)
# ==============================================================
RAZORPAY_KEY_ID=                # dashboard.razorpay.com → Account & Settings → API Keys
RAZORPAY_KEY_SECRET=            # paired with KEY_ID at creation
RAZORPAY_OFFER_BLOG20=          # created via Offers API after KYC+Magic Checkout
RAZORPAY_OFFER_FOUNDER50=       # created via Offers API after KYC+Magic Checkout
RAZORPAY_OFFER_LAUNCH30=        # created via Offers API after KYC+Magic Checkout
RAZORPAY_OFFER_STUDENT50=       # created via Offers API after KYC+Magic Checkout
RAZORPAY_PLAN_MAX_MONTHLY=      # dashboard → Subscriptions → Plans (plan_*)
RAZORPAY_PLAN_MAX_YEARLY=       # dashboard → Subscriptions → Plans (plan_*)
RAZORPAY_PLAN_PRO_MONTHLY=      # dashboard → Subscriptions → Plans (plan_*)
RAZORPAY_PLAN_PRO_YEARLY=       # dashboard → Subscriptions → Plans (plan_*)
RAZORPAY_WEBHOOK_SECRET=        # dashboard → Webhooks → secret on create

# ==============================================================
# SECTION 9: PADDLE (subscriptions — ROW USD rail; pending KYC)
# ==============================================================
PADDLE_API_KEY=                 # vendors.paddle.com → Developer Tools → Authentication
PADDLE_PRICE_MAX_MONTHLY=       # vendors.paddle.com → Catalog → Prices (pri_*)
PADDLE_PRICE_MAX_YEARLY=        # vendors.paddle.com → Catalog → Prices (pri_*)
PADDLE_PRICE_PRO_MONTHLY=       # vendors.paddle.com → Catalog → Prices (pri_*)
PADDLE_PRICE_PRO_YEARLY=        # vendors.paddle.com → Catalog → Prices (pri_*)
PADDLE_WEBHOOK_SECRET=          # vendors.paddle.com → Developer Tools → Notifications

# ==============================================================
# SECTION 10: AI PROVIDERS (20+ providers; OpenAI-compatible)
# ==============================================================
# Each provider has API_KEY (private — synced to repos)
# BASE_URL + CUSTOM_MODELS live in oriz-ai-providers-data repo (public catalog)
# Keep ONLY *_API_KEY in .env; remove *_BASE_URL + *_CUSTOM_MODELS (moved to data repo)
AGNES_API_KEY=                  # apihub.agnes-ai.com
CEREBRAS_API_KEY=               # cloud.cerebras.ai — free tier, no card
COHERE_API_KEY=                 # dashboard.cohere.com — free trial
FREETHEAI_XYZ_API_KEY=          # freetheai.xyz local proxy (sta_*)
GEMINI_API_KEY=                 # aistudio.google.com — free tier
GITHUB_COPILOT_PAT=             # github.com/settings/tokens (github_pat_*) — Models access
GROQ_API_KEY=                   # console.groq.com — free tier, no card
HUGGINGFACE_API_KEY=            # huggingface.co/settings/tokens — router.huggingface.co
HYPERSPACE_AI_API_KEY=          # local litellm proxy at :6655
KILO_CODE_API_KEY=              # kilocode.ai
LLM7_API_KEY=                   # llm7.io — free, anonymous
LM_STUDIO_API_KEY=              # local LM Studio at :1234 (use "PASS")
MISTRAL_API_KEY=                # console.mistral.ai — free tier
NVIDIA_API_KEY=                 # build.nvidia.com — free 5K req/mo
OLLAMA_CLOUD_API_KEY=           # ollama.com cloud tier
OMNIROUTE_API_KEY=              # local omniroute proxy at :20128
OPENCODE_ZEN_API_KEY=           # opencode.ai/zen
OPENROUTER_API_KEY=             # openrouter.ai — free :free models, no card
POLLINATION_API_KEY=            # text.pollinations.ai — free, no card
ROUTEWAY_API_KEY=               # api.routeway.ai
ZAI_API_KEY=                    # open.bigmodel.cn (Zhipu Z.AI)

# ==============================================================
# SECTION 11: CONTENT/MEDIA APIS
# ==============================================================
# Trakt (watched list) — trakt.tv/oauth/applications
TRAKT_ACCESS_TOKEN=             # OAuth dance output
TRAKT_CLIENT_ID=                # app create → Client ID
TRAKT_CLIENT_SECRET=            # app create → Client Secret
TRAKT_REFRESH_TOKEN=            # OAuth dance output (refresh)
# TMDB (movies/shows) — themoviedb.org/settings/api
TMDB_API_KEY=                   # v3 API key
TMDB_READ_ACCESS_TOKEN=         # v4 read access token (JWT)
# Last.fm (music) — last.fm/api/account/create
LASTFM_API_KEY=
# Spotify — developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=          # OAuth dance output
# Bluesky — bsky.app → Settings → App passwords
BLUESKY_APP_PASSWORD=
BLUESKY_HANDLE=                 # your.handle.bsky.social
# Dev.to — dev.to/settings/extensions
DEVTO_API_KEY=
# Media resilience layer (mostly empty)
FANART_API_KEY=                 # fanart.tv/get-an-api-key
OMDB_API_KEY=                   # omdbapi.com/apikey.aspx
STEAM_API_KEY=                  # steamcommunity.com/dev/apikey
STEAM_USER_ID=                  # steamcommunity.com/my (numeric ID)
TVDB_API_KEY=                   # thetvdb.com/api-information
TVMAZE_API_KEY=                 # tvmaze.com (no auth for free tier; reserved)
WATCHMODE_API_KEY=              # api.watchmode.com
YOUTUBE_API_KEY=                # console.cloud.google.com/apis/credentials
YOUTUBE_CHANNEL_ID=             # youtube.com → Settings → Advanced (UC*)

# ==============================================================
# SECTION 12: API SERVICE KEYS (for our own scraping APIs)
# ==============================================================
BING_SEARCH_API_KEY=            # azure.microsoft.com/services/cognitive-services/bing-web-search-api
INDIANRAIL_KEY=                 # oriz-irctc-train-pnr-api (provider TBD)
MAPS_API_KEY=                   # mapbox/google/maptiler — provider TBD
OPENAQ_KEY=                     # api.openaq.org — free air-quality data (oriz-aqi-cities-api)

# ==============================================================
# SECTION 13: DEPLOYMENT (mostly empty / legacy)
# ==============================================================
APPWRITE_API_KEY=               # cloud.appwrite.io → API Keys (legacy)
APPWRITE_PROJECT_ID=            # cloud.appwrite.io → Project Settings (legacy)
NEKOWEB_API_KEY=                # nekoweb.org → Settings → API key (legacy mirror)
NEOCITIES_API_KEY=              # neocities.org/settings → API key (legacy mirror)
PAGES_GAY_TOKEN=                # pages.gay deployment token (legacy mirror)
SOURCEHUT_TOKEN=                # meta.sr.ht/oauth — legacy mirror
SSH_PRIVATE_KEY=                # base64-encoded id_ed25519 (CI deploy key)
SURGE_LOGIN=                    # surge.sh email (legacy)
SURGE_TOKEN=                    # `surge token` output (legacy)

# ==============================================================
# SECTION 14: BUILD PERF
# ==============================================================
UV_THREADPOOL_SIZE=64
